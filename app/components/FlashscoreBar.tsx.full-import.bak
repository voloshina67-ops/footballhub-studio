"use client";

import { useState } from "react";
import { useMatchStore } from "../store/matchStore";
import { useLineupStore } from "../store/lineupStore";

export default function FlashscoreBar() {
  const [url, setUrl] = useState("");

  const setMatch = useMatchStore((s) => s.setMatch);
  const setPlayers = useLineupStore((s) => s.setPlayers);

  const loadMatch = async () => {
    try {
      const match = url.match(/mid=([A-Za-z0-9]+)/);

      if (!match) {
        alert("Не найден mid=");
        return;
      }

      const eventId = match[1];

      const res = await fetch(
        `/api/flashscore/${eventId}`
      );

      const json = await res.json();

      const event =
        json.data.findEventById;

      const home =
        event.eventParticipants.find(
          (p: any) =>
            p.type.side === "HOME"
        );

      const away =
        event.eventParticipants.find(
          (p: any) =>
            p.type.side === "AWAY"
        );

      setMatch(
        home.name,
        away.name,
        "",
        ""
      );

      const formation =
        home.lineup.formation.lines[0]
          .rows;

      const players =
        home.lineup.players;

      const fieldPlayers: any[] = [];

      const xMap = [
        10,
        28,
        46,
        64,
        82
      ];

      formation.forEach(
        (row: any, rowIndex: number) => {
          const count =
            row.playerIds.length;

          row.playerIds.forEach(
            (
              playerId: string,
              playerIndex: number
            ) => {
              const player =
                players.find(
                  (p: any) =>
                    p.id === playerId
                );

              if (!player) return;

              let y = 50;

              if (count === 1) {
                y = 50;
              } else {
                const step =
                  70 / (count - 1);

                y =
                  15 +
                  playerIndex * step;
              }

              const photo =
                player.images?.[0]
                  ?.path
                  ? `https://static.flashscore.com/res/image/data/${player.images[0].path}`
                  : "/player-placeholder.png";

              fieldPlayers.push({
                id: Date.now() + Math.random(),
                name:
                  player.fieldName ||
                  player.listName,
                photo,
                team: "home",
                x: xMap[rowIndex],
                y,
              });
            }
          );
        }
      );

      setPlayers(fieldPlayers);

      console.log(fieldPlayers);
    } catch (e) {
      console.error(e);
      alert("Ошибка импорта");
    }
  };

  return (
    <div className="mb-4 flex gap-3 rounded-2xl border border-white/10 bg-[#08152a] p-4">
      <input
        value={url}
        onChange={(e) =>
          setUrl(e.target.value)
        }
        placeholder="Flashscore URL..."
        className="flex-1 rounded-xl border border-white/10 bg-[#0b1727] px-4 py-3 text-white"
      />

      <button
        onClick={loadMatch}
        className="rounded-xl bg-green-600 px-6 font-bold text-white"
      >
        IMPORT LINEUP
      </button>
    </div>
  );
}
